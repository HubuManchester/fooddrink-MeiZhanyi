<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.HardwarePage"
             Title="Hardware Demo">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#FFF1DA, Dark=#130F0C}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#FFF9EF, Dark=#0F1711}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>

        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18" BackgroundColor="{AppThemeBinding Light=#FFFDF8, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Mobile hardware"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Demonstrate camera, location, speech, vibration, and haptic feedback."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Food photo" FontSize="17" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                            <Label Text="Capture the colour and condition of the meal." FontSize="13" TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Photo"
                                BackgroundColor="#D9472B"
                                TextColor="#FFFFFF"
                                Clicked="OnTakePhotoClicked"
                                SemanticProperties.Hint="Open the camera to capture a food image" />
                    </Grid>
                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#FFF0C9, Dark=#312316}"
                            HeightRequest="220">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image x:Name="FoodPhoto"
                               Aspect="AspectFill"
                               SemanticProperties.Description="Captured food photo preview" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Meal location" FontSize="17" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
                            <Label Text="Show country, city, region, and coordinates." FontSize="13" TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Locate"
                                BackgroundColor="#2F7A4F"
                                TextColor="#FFFFFF"
                                Clicked="OnGetLocationClicked"
                                SemanticProperties.Hint="Use location to record the meal place" />
                    </Grid>
                    <Label x:Name="LocationLabel"
                           Grid.Row="1"
                           Text="Location has not been captured yet."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
                    <Label x:Name="CoordinateLabel"
                           Grid.Row="2"
                           Text="Coordinates will appear here."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#9A7B63, Dark=#BFA58E}" />
                </Grid>
            </Border>

            
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Shake detection" 
                                   FontSize="17" 
                                   FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#7B4397, Dark=#D8A6FF}" />
                            <Label Text="Shake your phone to trigger an action." 
                                   FontSize="13" 
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                        </VerticalStackLayout>
                        <Button x:Name="AccelerometerButton"
                                Grid.Column="1"
                                Text="Start"
                                BackgroundColor="#7B4397"
                                TextColor="#FFFFFF"
                                Clicked="OnToggleAccelerometerClicked"
                                SemanticProperties.Hint="Start or stop shake detection" />
                    </Grid>
                    <Label x:Name="AccelerometerLabel"
                           Text="Accelerometer is off. Tap Start to begin."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
                    <Label x:Name="ShakeCountLabel"
                           Text="Shakes detected: 0"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#9A7B63, Dark=#BFA58E}" />
                </VerticalStackLayout>
            </Border>

            
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="Flashlight" 
                               FontSize="17" 
                               FontAttributes="Bold" 
                               TextColor="{AppThemeBinding Light=#E6A800, Dark=#FFD54F}" />
                        <Label Text="Use the camera flash as a torch for food photography." 
                               FontSize="13" 
                               TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                    </VerticalStackLayout>
                    <Button x:Name="FlashlightButton"
                            Grid.Column="1"
                            Text="Turn on"
                            BackgroundColor="#E6A800"
                            TextColor="#3A2518"
                            Clicked="OnToggleFlashlightClicked"
                            SemanticProperties.Hint="Turn the flashlight on or off" />
                </Grid>
            </Border>

            
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Compass" 
                                   FontSize="17" 
                                   FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#0077B6, Dark=#90E0EF}" />
                            <Label Text="Show which direction you are facing." 
                                   FontSize="13" 
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                        </VerticalStackLayout>
                        <Button x:Name="CompassButton"
                                Grid.Column="1"
                                Text="Start"
                                BackgroundColor="#0077B6"
                                TextColor="#FFFFFF"
                                Clicked="OnToggleCompassClicked"
                                SemanticProperties.Hint="Start or stop compass reading" />
                    </Grid>
                    <Label x:Name="CompassLabel"
                           Text="Compass is off. Tap Start to begin."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
                    <Label x:Name="CompassDirectionLabel"
                           Text="Direction: --"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#9A7B63, Dark=#BFA58E}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Read help"
                        BackgroundColor="#F29B38"
                        TextColor="#3A2518"
                        Clicked="OnReadHelpClicked"
                        SemanticProperties.Hint="Read the help text aloud" />
                <Button Grid.Column="1"
                        Text="Stop speech"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                        BorderColor="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop current speech" />
            </Grid>

            <Button Text="Haptic feedback"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    BorderColor="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BorderWidth="1"
                    TextColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}"
                    Clicked="OnFeedbackClicked"
                    SemanticProperties.Hint="Trigger vibration and haptic feedback" />

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFF0C9, Dark=#312316}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label x:Name="HardwareStatusLabel"
                           Text="Ready."
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#A95517, Dark=#FFD18E}" />
                    <Label x:Name="FeedbackCountLabel"
                           Text="Haptic feedback tests: 0"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
