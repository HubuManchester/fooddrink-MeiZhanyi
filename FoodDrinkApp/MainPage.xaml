<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.MainPage"
             Title="NutriBite">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#F0FDFA, Dark=#0F172A}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#ECFEFF, Dark=#1E293B}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>

        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Header Section -->
            <Border StrokeThickness="0" Padding="20" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#0D9488, Dark=#000000}"
                            Offset="0,4"
                            Radius="12"
                            Opacity="0.15" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Welcome to NutriBite"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Track your food and drink intake with ease"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                </VerticalStackLayout>
            </Border>

            <!-- Search Bar -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                    Padding="4">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <SearchBar x:Name="SearchFoodBar"
                           Placeholder="Search food items..."
                           PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}"
                           BackgroundColor="Transparent"
                           TextChanged="OnSearchTextChanged"
                           SearchButtonPressed="OnSearchButtonPressed"
                           SemanticProperties.Hint="Search for food items by name" />
            </Border>

            <!-- Stats Card -->
            <Border StrokeThickness="0" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light=#0D9488, Dark=#134E4A}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#14B8A6, Dark=#0F766E}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
                    <Label Text="Today's Calories"
                           FontSize="14"
                           TextColor="#CCFBF1" />
                    <Label Grid.Row="1"
                           Text="Track your intake"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF" />
                    <Label Grid.Column="1"
                           Grid.RowSpan="2"
                           Text="&#x1F525;"
                           FontSize="48"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Food List Header -->
            <Label Text="Your Food Items"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}"
                   Padding="4,8" />

            <!-- Food List -->
            <RefreshView x:Name="FoodRefreshView"
                         Refreshing="OnRefreshing"
                         RefreshColor="{AppThemeBinding Light=#0D9488, Dark=#5EEAD4}">
                <CollectionView x:Name="FoodCollection"
                                ItemsSource="{Binding}"
                                SelectionMode="None"
                                EmptyView="No food items yet. Tap Add to get started!">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#000000"
                                            Offset="0,2"
                                            Radius="8"
                                            Opacity="0.08" />
                                </Border.Shadow>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                    <!-- Food Icon -->
                                    <Border WidthRequest="50"
                                            HeightRequest="50"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#F0FDFA, Dark=#134E4A}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Label Text="&#x1F37D;"
                                               FontSize="24"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <!-- Food Info -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Category}"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                    </VerticalStackLayout>

                                    <!-- Details Button -->
                                    <Button Grid.Column="2"
                                            Text="View"
                                            BackgroundColor="{AppThemeBinding Light=#0D9488, Dark=#14B8A6}"
                                            TextColor="#FFFFFF"
                                            CornerRadius="8"
                                            Padding="12,8"
                                            CommandParameter="{Binding Id}"
                                            Clicked="OnDetailsClicked"
                                            SemanticProperties.Hint="View food details" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>