<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.AddItemPage"
             Title="Add Food">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#F0FDFA, Dark=#0F172A}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#ECFEFF, Dark=#1E293B}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>

        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Header -->
            <Border StrokeThickness="0" Padding="20" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#0D9488, Dark=#000000}"
                            Offset="0,4"
                            Radius="12"
                            Opacity="0.15" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Add New Item"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Fill in the details below to add food or drink"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                </VerticalStackLayout>
            </Border>

            <!-- Validation Panel -->
            <Border x:Name="ValidationPanel"
                    StrokeThickness="0"
                    BackgroundColor="#FEE2E2"
                    Padding="14"
                    IsVisible="False">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label x:Name="ValidationLabel"
                       Text=""
                       TextColor="#DC2626"
                       FontSize="14" />
            </Border>

            <!-- Form Card -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="20">

                    <!-- Name Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Name *"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0D9488, Dark=#5EEAD4}" />
                        <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                Padding="12,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="NameEntry"
                                   Placeholder="e.g. Grilled Chicken Salad"
                                   PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}"
                                   SemanticProperties.Hint="Enter food or drink name" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Category Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Category *"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0D9488, Dark=#5EEAD4}" />
                        <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                Padding="4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Picker x:Name="CategoryPicker"
                                    Title="Select a category"
                                    TitleColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                    TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}"
                                    SemanticProperties.Hint="Choose food category">
                                <Picker.Items>
                                    <x:String>Breakfast</x:String>
                                    <x:String>Lunch</x:String>
                                    <x:String>Dinner</x:String>
                                    <x:String>Snack</x:String>
                                    <x:String>Beverage</x:String>
                                    <x:String>Dessert</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Description Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Description *"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0D9488, Dark=#5EEAD4}" />
                        <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                Padding="12,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Editor x:Name="DescriptionEditor"
                                    Placeholder="Add notes about this item..."
                                    PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                    TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}"
                                    HeightRequest="80"
                                    SemanticProperties.Hint="Description for the food item" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Nutrition Section Header -->
                    <Label Text="Nutrition Information"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}"
                           Margin="0,8,0,0" />

                    <!-- Calories & Protein Row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Calories *"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0D9488, Dark=#5EEAD4}" />
                            <Border StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                    Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry x:Name="CaloriesEntry"
                                       Placeholder="e.g. 350"
                                       Keyboard="Numeric"
                                       PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="8">
                            <Label Text="Protein (g) *"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0D9488, Dark=#5EEAD4}" />
                            <Border StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                    Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry x:Name="ProteinEntry"
                                       Placeholder="e.g. 25"
                                       Keyboard="Numeric"
                                       PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Carbs & Fat Row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Carbs (g) *"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0D9488, Dark=#5EEAD4}" />
                            <Border StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                    Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry x:Name="CarbsEntry"
                                       Placeholder="e.g. 30"
                                       Keyboard="Numeric"
                                       PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="8">
                            <Label Text="Fat (g) *"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0D9488, Dark=#5EEAD4}" />
                            <Border StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                    Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry x:Name="FatEntry"
                                       Placeholder="e.g. 12"
                                       Keyboard="Numeric"
                                       PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Allergy Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Allergy Notes (Optional)"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0D9488, Dark=#5EEAD4}" />
                        <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                Padding="12,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="AllergyEntry"
                                   Placeholder="e.g. Contains nuts, dairy-free"
                                   PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F0FDFA}"
                                   SemanticProperties.Hint="Enter any allergy information" />
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Submit Button -->
            <Button x:Name="SaveButton"
                    Text="Save Item"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="54"
                    CornerRadius="12"
                    BackgroundColor="{AppThemeBinding Light=#0D9488, Dark=#14B8A6}"
                    TextColor="#FFFFFF"
                    Clicked="OnSaveClicked"
                    SemanticProperties.Hint="Save the new food item">
                <Button.Shadow>
                    <Shadow Brush="#0D9488"
                            Offset="0,4"
                            Radius="8"
                            Opacity="0.3" />
                </Button.Shadow>
            </Button>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
